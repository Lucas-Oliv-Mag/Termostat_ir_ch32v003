	)
	(text_box "________________________________\n	POWER PATH WITH 3.3V LDO\n\n* standard input voltage: 5V.\n* Output voltage: 3.3v +- 2%.\n* Standy by current: approx 3uA.\n* Max current allowed: 100mA"
