				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "162d2c55-462a-46a9-8515-2d02431a26b4")
	)
	(text_box "________________________________\n	I2C Peripheral bus\n* Connected to the OLED 0.96\" Display, \nAnd IR Temperature sensor.\n* fast mode (400Khz).\n* Pull-ups for clock and data lines."
		(exclude_from_sim no)
		(at 222.25 90.17 0)
		(size 45.72 16.51)
		(margins 0.9525 0.9525 0.9525 0.9525)
