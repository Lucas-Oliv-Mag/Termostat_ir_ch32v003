	(text_box "__________________________________________________________________\n	                MCU AND ADC CIRCUIT\n\n* Controls the I/Os, to improve interface with the SSD1306 and TP4056\n* Battery output voltage mensureament with overrange protection.\n* Bright mensureament for control the SSD1306 contrast.\n* Standy by current: approx 10uA.\n* Standard current: aprrox 5mA."
		(exclude_from_sim no)
		(at 101.6 88.9 0)
		(size 76.2 17.78)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
		)
		(fill
			(type none)
		)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "162d2c55-462a-46a9-8515-2d02431a26b4")
	)
	(text_box "________________________________\n	I2C Peripheral bus\n* Connected to the OLED 0.96\" Display, \nAnd IR Temperature sensor.\n* fast mode (400Khz).\n* Pull-ups for clock and data lines."
		(exclude_from_sim no)
		(at 222.25 90.17 0)
		(size 45.72 16.51)
		(margins 0.9525 0.9525 0.9525 0.9525)
