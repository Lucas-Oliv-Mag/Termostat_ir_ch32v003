		)
		(uuid "30216a5b-d2b6-48f8-afe4-f9ca675aed34")
	)
	(text_box "________________________________\n	DESACOUPLING CAPACITORS\n\n* MCU, OLED DISPLAY, IR Sensor."
		(exclude_from_sim no)
		(at 29.21 158.75 0)
		(size 36.83 12.7)
